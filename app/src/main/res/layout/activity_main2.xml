<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/secondback"
    android:padding="30dp">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:orientation="vertical">

        <!-- 🔹 Projects Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/project"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/projectsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Projects"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- 🔹 Project Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Medical Assistant Chatbot"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#37474F" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="An AI-powered chatbot built using Kotlin and Firebase to help users log symptoms and receive guidance."
                    android:textSize="14sp"
                    android:textColor="#37474F" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <!-- 🔹 Education Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/education"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/educationHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Education"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- 🔹 B.Tech Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="B.Tech in Computer Science"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#37474F" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOVELY PROFESSIONAL UNIVERSITY | 2024 - 2027"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CGPA: 8.7"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🔹 Diploma Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Diploma in Electrical Engineering"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#37474F" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GOVERNMENT POLYTECHNIC MOTIHARI | 2021 - 2024"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CGPA: 7.8"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <!-- 🔹 Certificates Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/certificate"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/certificatesHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Certificates"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- 🔹 Certificates Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✔ Android Development - Google"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✔ Java Programming - neocolab"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✔ Data Science with Python - Coursera"
                    android:textSize="14sp"
                    android:textColor="#37474F" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🔹 Skills Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/skills"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/skillsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skills"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- 🔹 Skills Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Kotlin, Java, Python"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Android Studio, Firebase, Git"
                    android:textSize="14sp"
                    android:textColor="#37474F"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Data Analysis, Machine Learning Basics"
                    android:textSize="14sp"
                    android:textColor="#37474F" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 🔹 View Resume Button -->
        <Button
            android:id="@+id/viewResumeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Resume"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:elevation="4dp"
            android:fontFamily="sans-serif-medium"
            android:background="@color/white"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="8dp"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>